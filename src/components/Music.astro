<style>
  .music-coming {
    text-align: center;
    padding: 4rem 2rem;
    background: rgba(33, 1, 36, 0.3);
    border: 1px solid rgba(114, 109, 168, 0.15);
    border-radius: 24px;
  }

  .waveform {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3px;
    height: 60px;
    margin-bottom: 2rem;
  }

  .wave-bar {
    width: 4px;
    height: var(--h);
    background: linear-gradient(to top, var(--dusty-grape), var(--glaucous));
    border-radius: 2px;
    animation: wave 1.5s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.05s);
    opacity: 0.6;
  }

  @keyframes wave {
    0%, 100% { transform: scaleY(0.4); }
    50% { transform: scaleY(1); }
  }

  .music-coming h3 {
    font-size: 1.8rem;
    margin-bottom: 1rem;
    font-family: 'Space Grotesk', sans-serif;
  }

  .music-coming p {
    color: rgba(219, 249, 244, 0.6);
    font-size: 1.05rem;
    max-width: 500px;
    margin: 0 auto 2.5rem;
  }

  .platforms {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }

  .platform-link {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid rgba(114, 109, 168, 0.3);
    color: var(--glaucous);
    transition: all 0.3s ease;
  }

  .platform-link:hover {
    background: rgba(114, 109, 168, 0.2);
    border-color: var(--dusty-grape);
    color: var(--frozen-water);
    transform: translateY(-3px);
  }
</style>
