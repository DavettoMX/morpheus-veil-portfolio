<section class="section contact fade-in" id="contact">
  <h2 class="section-title">Contact</h2>

  <div class="contact-layout">
    <!-- Booking -->
    <div class="contact-card">
      <h3>Booking</h3>
      <p>Interested in booking Morpheus Veil for your event, festival or venue.</p>
      <form class="contact-form" id="bookingForm" name="booking" method="POST" data-netlify="true">
        <div class="form-group">
          <input type="text" name="name" placeholder="Name / Organization" required />
        </div>
        <div class="form-group">
          <input type="email" name="email" placeholder="Email" required />
        </div>
        <div class="form-group">
          <input type="text" name="event" placeholder="Event type" />
        </div>
        <div class="form-group">
          <input type="date" name="date" placeholder="Tentative date" />
        </div>
        <div class="form-group">
          <textarea name="message" rows="3" placeholder="Additional details"></textarea>
        </div>
        <button type="submit" class="btn-submit">Send Request</button>
      </form>
    </div>

    <!-- General + Newsletter -->
    <div class="contact-right">
      <!-- Newsletter -->
      <div class="contact-card newsletter-card">
        <h3>Newsletter</h3>
        <p>Be the first to know about new releases, tour dates and exclusive content.</p>
        <form class="newsletter-form" id="newsletterForm" name="newsletter">
          <div class="newsletter-input-group">
            <input type="email" name="email" placeholder="Your email" required />
            <button type="submit" class="btn-newsletter">Subscribe</button>
          </div>
        </form>
      </div>

      <!-- Redes + Contacto general -->
      <div class="contact-card">
        <h3>Connect</h3>
        <p>Collaborations, proposals or just say hello.</p>
        <div class="social-links">
          <a href="https://instagram.com/morpheus.veil" target="_blank" rel="noopener" class="social-link" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
            <span>Instagram</span>
          </a>
          <a href="https://x.com/MorpheusVeil_" target="_blank" rel="noopener" class="social-link" aria-label="Twitter / X">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            <span>X (Twitter)</span>
          </a>
          <a href="https://tiktok.com/@morpheus.veil" target="_blank" rel="noopener" class="social-link" aria-label="TikTok">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.46v-7.13a8.16 8.16 0 005.58 2.18v-3.47a4.85 4.85 0 01-1-.55z"/>
            </svg>
            <span>TikTok</span>
          </a>
          <a href="mailto:contact@morpheusveil.com" class="social-link" aria-label="Email">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <span>contact@morpheusveil.com</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="footer">
  <p>&copy; 2026 Morpheus Veil. All rights reserved.</p>
</footer>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: stretch;
  }

  .contact-card {
    background: rgba(33, 1, 36, 0.3);
    border: 1px solid rgba(114, 109, 168, 0.15);
    border-radius: 20px;
    padding: 2rem;
  }

  .contact-card h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.3rem;
    margin-bottom: 0.6rem;
  }

  .contact-card > p {
    font-size: 0.95rem;
    color: rgba(219, 249, 244, 0.6);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .contact-right {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Forms */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.9rem 1.1rem;
    background: rgba(4, 3, 3, 0.5);
    border: 1px solid rgba(114, 109, 168, 0.2);
    border-radius: 10px;
    color: var(--frozen-water);
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.3s ease;
    resize: vertical;
  }

  .form-group input[type="date"] {
    color-scheme: dark;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(125, 140, 196, 0.4);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--dusty-grape);
  }

  .btn-submit {
    padding: 0.9rem 1.8rem;
    background: linear-gradient(135deg, var(--dusty-grape), var(--glaucous));
    color: var(--frozen-water);
    border: none;
    border-radius: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    margin-top: 0.3rem;
  }

  .btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(114, 109, 168, 0.3);
  }

  /* Newsletter */
  .newsletter-form {
    margin-top: 0;
  }

  .newsletter-input-group {
    display: flex;
    gap: 0.5rem;
  }

  .newsletter-input-group input {
    flex: 1;
    padding: 0.9rem 1.1rem;
    background: rgba(4, 3, 3, 0.5);
    border: 1px solid rgba(114, 109, 168, 0.2);
    border-radius: 10px;
    color: var(--frozen-water);
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.3s ease;
  }

  .newsletter-input-group input::placeholder {
    color: rgba(125, 140, 196, 0.4);
  }

  .newsletter-input-group input:focus {
    border-color: var(--dusty-grape);
  }

  .btn-newsletter {
    padding: 0.9rem 1.5rem;
    background: linear-gradient(135deg, var(--dusty-grape), var(--glaucous));
    color: var(--frozen-water);
    border: none;
    border-radius: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .btn-newsletter:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(114, 109, 168, 0.3);
  }

  /* Social */
  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--glaucous);
    font-size: 0.9rem;
    padding: 0.7rem 0.9rem;
    border-radius: 10px;
    border: 1px solid rgba(114, 109, 168, 0.12);
    transition: all 0.3s ease;
  }

  .social-link:hover {
    background: rgba(114, 109, 168, 0.1);
    border-color: rgba(114, 109, 168, 0.35);
    color: var(--frozen-water);
    transform: translateX(4px);
  }

  .form-success {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--glaucous);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .footer {
    text-align: center;
    padding: 2rem;
    border-top: 1px solid rgba(114, 109, 168, 0.1);
    color: rgba(219, 249, 244, 0.3);
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }

    .newsletter-input-group {
      flex-direction: column;
    }
  }
</style>

<script>
  // Booking form -> Netlify Forms
  document.getElementById('bookingForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const btn = form.querySelector('button[type="submit"]');
    const originalText = btn.textContent;
    btn.textContent = 'Sending...';
    btn.disabled = true;

    try {
      const formData = new FormData(form);
      formData.append('form-name', 'booking');
      const response = await fetch('/forms.html', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(formData).toString(),
      });

      if (response.ok) {
        const msg = document.createElement('p');
        msg.className = 'form-success';
        msg.textContent = 'Got it! We\'ll be in touch soon.';
        form.replaceWith(msg);
      } else {
        btn.textContent = 'Error, try again';
        btn.disabled = false;
        setTimeout(() => { btn.textContent = originalText; }, 3000);
      }
    } catch {
      btn.textContent = 'Error, try again';
      btn.disabled = false;
      setTimeout(() => { btn.textContent = originalText; }, 3000);
    }
  });

  // Newsletter form -> Buttondown API via Netlify Function
  document.getElementById('newsletterForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const btn = form.querySelector('button[type="submit"]');
    const originalText = btn.textContent;
    const email = form.querySelector('input[name="email"]').value;
    btn.textContent = 'Sending...';
    btn.disabled = true;

    try {
      const response = await fetch('/.netlify/functions/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (response.ok) {
        const msg = document.createElement('p');
        msg.className = 'form-success';
        msg.textContent = 'Welcome aboard! Thanks for joining this crazy journey.';
        form.replaceWith(msg);
      } else {
        btn.textContent = 'Error, try again';
        btn.disabled = false;
        setTimeout(() => { btn.textContent = originalText; }, 3000);
      }
    } catch {
      btn.textContent = 'Error, try again';
      btn.disabled = false;
      setTimeout(() => { btn.textContent = originalText; }, 3000);
    }
  });
</script>
