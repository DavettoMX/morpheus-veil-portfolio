---
const months = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
const now = new Date();
const todayFormatted = `${months[now.getMonth()]} ${now.getDate()}, ${now.getFullYear()}`;
const currentYear = now.getFullYear();
---

<section class="section tour" id="tour">
  <h2 class="section-title">Tour</h2>

  <div class="tour-container">
    <div class="tour-tabs">
      <button class="tour-tab active">Upcoming</button>
      <span class="tab-divider">|</span>
      <button class="tour-tab">Past</button>
      <span class="tab-divider">|</span>
      <button class="tour-tab">Near Me</button>
    </div>

    <div class="tour-list">
      <div class="tour-row">
        <div class="tour-date-info">
          <span class="tour-date">{todayFormatted}</span>
          <span class="tour-city">My Bedroom, MX</span>
          <span class="tour-venue">Unplugged Sessions</span>
        </div>
        <div class="tour-actions">
          <button class="notify-btn" aria-label="Notificar">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
              <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
          </button>
          <a href="#" class="ticket-btn">SOLD OUT</a>
        </div>
      </div>

      <div class="tour-row tour-row--cta">
        <div class="tour-date-info">
          <span class="tour-date">COMING SOON</span>
          <span class="tour-city">Somewhere in the World</span>
          <span class="tour-venue">Check back for any announcements regarding live performances in {currentYear}.</span>
        </div>
        <div class="tour-actions">
          <a href="#contact" class="ticket-btn ticket-btn--booking">BOOKING</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .tour .tour-container {
    width: 100%;
    background: rgba(4, 3, 3, 0.8);
    border: 1px solid rgba(114, 109, 168, 0.12);
    border-radius: 16px;
    overflow: hidden;
  }

  .tour .tour-tabs {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.2rem 1.8rem;
    border-bottom: 1px solid rgba(114, 109, 168, 0.15);
  }

  .tour .tour-tab {
    background: none;
    border: none;
    color: rgba(219, 249, 244, 0.4);
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: color 0.3s ease;
    padding: 0;
  }

  .tour .tour-tab.active {
    color: var(--frozen-water);
  }

  .tour .tour-tab:hover {
    color: var(--frozen-water);
  }

  .tour .tab-divider {
    color: rgba(219, 249, 244, 0.15);
    font-size: 0.9rem;
  }

  .tour .tour-list {
    display: flex;
    flex-direction: column;
  }

  .tour .tour-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.3rem 1.8rem;
    border-bottom: 1px solid rgba(114, 109, 168, 0.08);
    transition: background 0.2s ease;
  }

  .tour .tour-row:last-child {
    border-bottom: none;
  }

  .tour .tour-row:hover {
    background: rgba(114, 109, 168, 0.06);
  }

  .tour .tour-row--cta {
    border-top: 1px dashed rgba(114, 109, 168, 0.15);
  }

  .tour .tour-date-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .tour .tour-date {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--frozen-water);
    letter-spacing: 0.5px;
  }

  .tour .tour-city {
    font-size: 0.9rem;
    color: rgba(219, 249, 244, 0.6);
  }

  .tour .tour-venue {
    font-size: 0.9rem;
    color: rgba(219, 249, 244, 0.4);
  }

  .tour .tour-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .tour .notify-btn {
    background: none;
    border: none;
    color: rgba(219, 249, 244, 0.4);
    cursor: pointer;
    padding: 0.4rem;
    transition: color 0.3s ease;
    display: flex;
    align-items: center;
  }

  .tour .notify-btn:hover {
    color: var(--frozen-water);
  }

  .tour .ticket-btn {
    padding: 0.55rem 1.4rem;
    background: var(--frozen-water);
    color: var(--black);
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .tour .ticket-btn:hover {
    background: var(--glaucous);
    color: var(--frozen-water);
  }

  .tour .ticket-btn--booking {
    background: linear-gradient(135deg, var(--dusty-grape), var(--glaucous));
    color: var(--frozen-water);
  }

  .tour .ticket-btn--booking:hover {
    box-shadow: 0 4px 20px rgba(114, 109, 168, 0.4);
  }

  @media (max-width: 768px) {
    .tour .tour-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.2rem 1.5rem;
    }

    .tour .tour-actions {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>
