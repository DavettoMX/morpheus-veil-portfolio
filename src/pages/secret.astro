---
import Layout from '../layouts/Layout.astro';
---

<Layout title="??? | Morpheus Veil">
  <div class="secret-page">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <div class="secret-content" id="secretContent">
      <div class="secret-phase active" data-phase="0">
        <p class="secret-main">Not everything is what it seems.</p>
        <p class="secret-sub">The veil is thin.</p>
      </div>
      <div class="secret-phase" data-phase="1">
        <p class="secret-main">You weren't supposed to find this.</p>
        <p class="secret-sub">Or maybe you were.</p>
      </div>
      <div class="secret-phase" data-phase="2">
        <p class="secret-main">This page will mean something soon.</p>
        <p class="secret-accent">Remember the code.</p>
      </div>
    </div>

    <a href="/" class="secret-back" id="secretBack">Wake up</a>
  </div>
</Layout>

<style>
  .secret-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 2rem;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.2;
    animation: drift 10s ease-in-out infinite;
  }

  .orb-1 {
    width: 500px;
    height: 500px;
    background: var(--dusty-grape);
    top: -20%;
    left: -10%;
  }

  .orb-2 {
    width: 400px;
    height: 400px;
    background: var(--glaucous);
    bottom: -20%;
    right: -10%;
    animation-delay: -5s;
  }

  @keyframes drift {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(30px, -20px); }
  }

  .secret-content {
    position: relative;
    z-index: 1;
    text-align: center;
    width: 90vw;
    max-width: 600px;
    height: 150px;
  }

  .secret-phase {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .secret-phase.active {
    opacity: 1;
    visibility: visible;
  }

  .secret-phase.glitching {
    animation: phaseGlitch 0.4s linear;
  }

  .secret-main {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.3rem;
    color: rgba(219, 249, 244, 0.7);
    line-height: 1.6;
  }

  .secret-sub {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem;
    color: var(--glaucous);
    line-height: 1.6;
  }

  .secret-accent {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--dusty-grape);
    line-height: 1.6;
  }

  @keyframes phaseGlitch {
    0% { transform: translate(0); filter: blur(0); opacity: 1; }
    15% { transform: translate(-4px, 2px) skewX(2deg); filter: blur(2px); opacity: 0.6; }
    30% { transform: translate(3px, -1px) skewX(-1deg); filter: blur(4px); opacity: 0.3; }
    45% { transform: translate(-2px, -2px); filter: blur(6px); opacity: 0; }
    55% { transform: translate(2px, 1px); filter: blur(6px); opacity: 0; }
    70% { transform: translate(-3px, 2px) skewX(1deg); filter: blur(4px); opacity: 0.3; }
    85% { transform: translate(4px, -1px) skewX(-2deg); filter: blur(2px); opacity: 0.6; }
    100% { transform: translate(0); filter: blur(0); opacity: 1; }
  }

  .secret-back {
    position: relative;
    z-index: 1;
    margin-top: 3rem;
    color: rgba(219, 249, 244, 0.2);
    font-size: 0.85rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0;
    visibility: hidden;
    transition: opacity 1s ease, color 0.3s ease;
  }

  .secret-back.visible {
    opacity: 1;
    visibility: visible;
  }

  .secret-back:hover {
    color: var(--frozen-water);
  }
</style>

<script>
  const phases = document.querySelectorAll('.secret-phase');
  const back = document.getElementById('secretBack');
  let current = 0;
  const totalPhases = phases.length;

  function glitchTransition() {
    if (current >= totalPhases - 1) {
      setTimeout(() => back?.classList.add('visible'), 1000);
      return;
    }

    setTimeout(() => {
      const currentPhase = phases[current];
      currentPhase.classList.add('glitching');

      setTimeout(() => {
        currentPhase.classList.remove('active', 'glitching');
        current++;
        const nextPhase = phases[current];
        nextPhase.classList.add('glitching');
        setTimeout(() => {
          nextPhase.classList.remove('glitching');
          nextPhase.classList.add('active');
          glitchTransition();
        }, 400);
      }, 400);
    }, 3000);
  }

  glitchTransition();
</script>
